# Copia este archivo a ".env.local" y completa con tus datos de Supabase (sección 3.1)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# El número de WhatsApp YA NO se configura aquí: se lee desde la columna "whatsapp"
# de la tabla "tiendas" en Supabase (sección 3.2). Actualízalo con este SQL, reemplazando
# NOMBRE_DE_TU_TIENDA por el valor real de la columna "nombre" en tu tabla tiendas:
#
# update tiendas set whatsapp = '59175643335' where nombre = 'NOMBRE_DE_TU_TIENDA';
#
# Si tu tabla tiendas aún está vacía, primero crea la fila de tu tienda:
# insert into tiendas (nombre, whatsapp, moneda, slug)
# values ('nugastore', '59175643335', 'BOB', 'nugastore');
